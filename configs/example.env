# Data locations. FLORES-200 is obtained separately.
DEMO_POOL=/path/to/flores200/eng_Latn-hau_Latn_dev.jsonl
EVALUATION_SET=/path/to/flores200/eng_Latn-hau_Latn_devtest.jsonl

# Model locations.
TRANSLATOR_MODEL=/path/to/model
XCOMET_MODEL=/path/to/model/xcomet/checkpoints/model.ckpt
COMET22_MODEL=/path/to/model/wmt22-comet-da/checkpoints/model.ckpt
QE_MODEL=/path/to/model/wmt22-cometkiwi-da
GTE_MODEL=/path/to/model/gte-multilingual-base
SONAR_MODEL=/path/to/model/text_sonar_basic_encoder

# Example run configuration.
SOURCE_LANGUAGE=English
TARGET_LANGUAGE=Hausa
LANGUAGE_PAIR=eng_Latn-hau_Latn
MODEL_FAMILY=qwen3
RETRIEVER=bm25
SELECTOR_METHOD=error_filter
CANDIDATE_SIZE=50
SHOTS=8
DEVICE=cuda
